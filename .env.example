# Chrome実行ファイル (WSLからWindows側を指定する場合の例)
CHROME_PATH=/mnt/c/Program Files/Google/Chrome/Application/chrome.exe

# Chromeのプロファイル/データディレクトリ (Windows側パス)
CHROME_USER_DATA=C:\\Users\\YOUR_USERNAME\\AppData\\Local\\Google\\Chrome\\User Data
CHROME_PROFILE=Default

# Gemini操作系で使うエンドポイント
GEMINI_URL=https://gemini.google.com/app

# 出力先（ローカル相対パス）
OUTPUT_DIR=./output
